        </SetRegEntry>
        <SetRegEntry>
          <Number>0</Number>
          <Key>UL2V8M</Key>
          <Name>UL2V8M(-S0 -C0 -P0 )  -FN3 -FC7800 -FD20000000 -FF0RA6M5_1M -FF1RA6M5_DATA_C1M -FF2RA6M5_CONF -FL0100000 -FL12000 -FL2200 -FS00 -FS18000000 -FS2100A100 -FP0($$Device:R7FA6M5BF$Flash\RA6M5_1M.FLM) -FP1($$Device:R7FA6M5BF$Flash\RA6M5_DATA_C1M.FLM) -FP2($$Device:R7FA6M5BF$Flash\RA6M5_CONF.FLM)</Name>
        </SetRegEntry>
      </TargetDriverDllRegistry>
